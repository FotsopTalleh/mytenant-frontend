# ── MyTenant Frontend ─────────────────────────────────────────────────────────
# Dev: leave as /api so ALL requests go through the Vite proxy → Flask.
#      The proxy strips /api and forwards to http://localhost:5000.
#      This keeps cookies same-origin (no SameSite/Secure cross-origin issues).
# Prod: set to your deployed Flask URL e.g. https://api.mytenant.app
VITE_API_URL=/api

# SSR URL — used by the TanStack Start SSR server when rendering on the Node.js side.
# The Vite proxy is NOT available during SSR, so we need the direct Flask URL.
# Local dev:  http://localhost:5000
# Production: same as VITE_API_URL (your deployed Flask URL)
VITE_API_SSR_URL=http://localhost:5000

# Google OAuth — must match the client ID configured in Google Cloud Console.
# Authorised JS origins must include http://localhost:3000 (or Vite dev port)
# Authorised redirect URIs: not needed for GIS popup flow
VITE_GOOGLE_CLIENT_ID=377250835100-aaqfn4hdd62el7sa727q7i8ocfcbiumv.apps.googleusercontent.com
